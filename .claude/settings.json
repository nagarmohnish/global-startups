    "deny": [
      // ══════════════════════════════════════════════════
      //  SAFETY NET — block the truly dangerous stuff
      // ══════════════════════════════════════════════════
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/)",
      "Bash(sudo rm -rf:*)",
      "Bash(mkfs:*)",
      "Bash(dd if=:*)",
      "Bash(:(){ :|:& };:)",

      // Protect secrets
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/secrets/**)",
      "Read(**/*credentials*)",
      "Read(**/*secret*)",
      "Read(**/apikey*)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/credentials)",
      "Read(~/.gnupg/**)",

      // Block publishing / destructive deploys
      "Bash(npm publish:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)"
